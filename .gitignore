.history/
# .claude/
# .cline/
# .roo/
# .opencode/
*.code-workspace

# --- Python & Build ---
__pycache__/
*.pyc
.pytest_cache/

# --- Persistent State ---
resume-session.state
resume_session.state

# --- Temporary & Development Artifacts ---
scratch/
# *.txt
# *.patch
# *.log
# *.bak
# *.old
# *temp*
# test*.py
# test*.lua
# old.lua
# parsed_subs*
tests/mpv_last_run.log
pytest_out.log
.pytest_tmp/

