# --- System & IDE ---
.history/
.claude/
.cline/
.roo/
.opencode/
*.code-workspace

# --- Python & Build ---
__pycache__/
*.pyc
.pytest_cache/
tests/mpv_last_run.log

# --- Persistent State ---
resume-session.state

# --- Temporary & Development Artifacts ---
scratch/
*.txt
*.patch
*.log
*.bak
*.old
*temp*
test*.py
test*.lua
old.lua
parsed_subs*

# --- Specific Legacy Exclusions ---
scripts/*_old*.lua
scripts/test_osd.lua
scripts/old_copy_sub.lua
scripts/lls_core_good*.lua
20260304233334-you-dont-need-saas.ass
tests/fixtures/20260502165659-test-fixture.tsv

